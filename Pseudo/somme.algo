// Ver. FR
Algorithme somme;
Var
    n, s : entier;
Début
    Ecrire("saisez n : ");
    Lire(n);
    s <-- 0;
    Pour i <-- 1 à n faire
        s <-- s + i;
    FinSi;
    Ecrire("la somme des nombres de 0 à ", n, " est ", s);
Fin.

// ENG Ver.
Algorithm sum;
Var
    n, s : Integer;
Begin
    Write("Enter n : ");
    Read(n);
    s <-- 0;
    For i <-- 1 to n do
        s <-- s + i;
    EndFor;
    Write("The sum of all numbers from 0 to ", n, " is ", s);
End.
