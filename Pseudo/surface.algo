// Ver. FR
Algorithme surface;
Var
    x, y, s : Float;
Début
    Ecrire("Saisez la longueur et la largeur: ");
    Lire(x, y);
    s <-- x * y;
    Ecrire("La surface est ", s);
Fin.

// ENG Ver.
Algorithm area;
Var
    x, y, a : Float;
Begin
    Write("Enter the length and width : ");
    Read(x, y);
    a <-- x * y;
    Write("The area is ", a);
End.